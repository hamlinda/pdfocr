# List of directories to scan, comma-separated (relative to app or absolute paths)
SCAN_DIRECTORIES=/mnt/backup

# Subfolder where non-searchable files will be copied and processed
OCR_SUBFOLDER=_newOCR

# Path to the log file
LOG_FILE=pdf_ocr.log

# Language for OCR (default: eng)
OCR_LANG=eng

# Force OCR even if text is already present in the PDF (True or False)
FORCE_OCR=False
